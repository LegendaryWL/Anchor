anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
color = Color(0.018, 0.02, 0.025, 1)

[node name="HUD" type="Control" parent="CanvasLayer/UI"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("2_hud")
san_label_path = NodePath("TopLeftPanel/VBox/SanLabel")
san_bar_path = NodePath("TopLeftPanel/VBox/SanBar")
